# Database
DATABASE_URL=postgresql://deploy_agent:localdev@localhost:5432/deploy_agent

# LLM (Claude primary, GPT-5.4 fallback)
ANTHROPIC_API_KEY=sk-ant-xxx
LLM_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-5.4

# GCP (for deployment)
GCP_PROJECT=your-project-id
GCP_REGION=asia-east1
GCP_STORAGE_BUCKET=your-bucket

# App
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# GitHub (for PR creation)
GITHUB_TOKEN=ghp_xxx

# Cloudflare DNS (for custom domain binding)
CLOUDFLARE_TOKEN=cfat_xxx
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_ZONE_NAME=example.com

# Notifications (optional)
SLACK_WEBHOOK_URL=
