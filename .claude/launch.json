{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "deploy-agent-api",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "watch", "deploy-agent/apps/api/src/index.ts"],
      "port": 4000
    },
    {
      "name": "deploy-agent-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "deploy-agent/apps/web", "run", "dev", "--", "--port", "3000"],
      "port": 3000
    }
  ]
}
