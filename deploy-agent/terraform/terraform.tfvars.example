# Copy to terraform.tfvars (gitignored) and fill in real values.

gcp_project = "wave-deploy-agent"
gcp_region  = "asia-east1"
redis_zone  = "asia-east1-b"

api_domain   = "wave-deploy-agent-api.punwave.com"
web_domain   = "wave-deploy-agent.punwave.com"
cors_origins = "https://wave-deploy-agent.punwave.com"

cloudflare_zone_id   = "<cloudflare-zone-id>"
cloudflare_zone_name = "punwave.com"

# Secrets — fill from 1Password / existing prod env vars
db_password        = "CHANGE_ME"
redis_password     = "CHANGE_ME"
anthropic_api_key  = "sk-ant-..."
openai_api_key     = "sk-..."
github_token       = "ghp_..."
cloudflare_token   = "cfat_..."
